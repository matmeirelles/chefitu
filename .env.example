DATABASE_URL="postgresql://my_recipes:my_recipes@localhost:5432/my_recipes?schema=public"
PORT=3333
HOST=0.0.0.0
EXPO_PUBLIC_API_BASE_URL="http://127.0.0.1:3333"
# Restrict allowed origins in production, e.g. CORS_ORIGIN="https://app.myrecipes.com"
# CORS_ORIGIN=

