{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "noImplicitAny": true,
    "strictNullChecks": true,
    "noImplicitThis": true,
    "noImplicitOverride": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@chefitu/shared": ["../../packages/shared/src/index.ts"]
    }
  },
  "include": ["App.tsx", "index.js", "src/**/*.ts", "src/**/*.tsx"]
}
