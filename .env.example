# ─── Local Development ────────────────────────────────────────────────────────
DATABASE_URL="postgresql://my_recipes:my_recipes@localhost:5432/my_recipes?schema=public"
PORT=3333
HOST=0.0.0.0
EXPO_PUBLIC_API_BASE_URL="http://127.0.0.1:3333"

# Restrict allowed origins in production (mobile apps don't need this)
# CORS_ORIGIN=

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Uncomment ONE block below.

# Anthropic (recommended for production)
# AI_PROVIDER="anthropic"
# AI_MODEL="claude-haiku-4-5"
# ANTHROPIC_API_KEY=""

# Ollama local
# AI_PROVIDER="ollama"
# AI_MODEL="llama3.1:8b"
# OLLAMA_BASE_URL="http://127.0.0.1:11434"

# ─── Railway Production (set these in Railway dashboard, not here) ────────────
# DATABASE_URL        → auto-injected when you link a PostgreSQL service
# PORT                → auto-injected by Railway
# HOST=0.0.0.0
# NODE_ENV=production
# AI_PROVIDER=anthropic
# AI_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...
